<!-- OpenArm v10 7-DOF Single Arm — MuJoCo MJCF
     Generated from bsreal/robot_data/openarm_data.py inertial parameters.
     Joint axes: Z, -X, Z, Y, Z, X, Y
     Joint limits (deg): j1[-75,75] j2[-9,90] j3[-85,85] j4[0,135] j5[-85,85] j6[-40,40] j7[-80,80]
-->
<mujoco model="openarm7">
  <compiler angle="radian" inertiafromgeom="false"/>

  <option gravity="0 0 -9.81" timestep="0.002"/>

  <default>
    <joint damping="0.5" armature="0.001"/>
    <geom contype="1" conaffinity="1" rgba="0.7 0.7 0.7 1"/>
    <motor ctrlrange="-50 50" ctrllimited="true"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" width="512" height="512"/>
    <material name="floor_mat" texture="grid" texrepeat="8 8" reflectance="0.2"/>
    <material name="link_mat" rgba="0.6 0.65 0.7 1"/>
    <material name="joint_mat" rgba="0.3 0.3 0.8 1"/>
    <material name="ee_mat" rgba="0.9 0.2 0.2 1"/>
  </asset>

  <worldbody>
    <light diffuse="0.8 0.8 0.8" pos="0 0 3" dir="0 0 -1"/>
    <geom type="plane" size="2 2 0.01" material="floor_mat"/>

    <!-- Target site (moved by env at each reset) -->
    <body name="target" pos="0.3 0 0.5" mocap="true">
      <geom type="sphere" size="0.02" rgba="1 0.2 0.2 0.5" contype="0" conaffinity="0"/>
    </body>

    <!-- Base mount (fixed) -->
    <body name="base" pos="0 0 0.698">
      <geom type="cylinder" size="0.04 0.03" rgba="0.4 0.4 0.4 1"/>

      <!-- Link 0 / Joint 1 (Z-axis) -->
      <body name="link0" pos="0 0 0.0625">
        <joint name="j1" type="hinge" axis="0 0 1"
               limited="true" range="-1.309 1.309"/>
        <inertial pos="0.00115 0.0000332 0.0540"
                  mass="1.1417"
                  fullinertia="0.001567 0.001273 0.001016 -1e-06 -2.9e-05 1e-06"/>
        <geom type="capsule" fromto="0 0 0  0 0 0.06" size="0.03" material="link_mat"/>
        <geom type="sphere" pos="0 0 0" size="0.025" material="joint_mat"/>

        <!-- Link 1 / Joint 2 (-X axis, with 90° X rotation) -->
        <body name="link1" pos="-0.0301 0 0.06" euler="1.5708 0 0">
          <joint name="j2" type="hinge" axis="-1 0 0"
                 limited="true" range="-0.157 1.571"/>
          <inertial pos="0.00840 0.0 0.03257"
                    mass="0.2775"
                    fullinertia="0.000359 0.000376 0.000232 1e-06 -0.000109 1e-06"/>
          <geom type="capsule" fromto="0 0 0  0 0 0.065" size="0.022" material="link_mat"/>
          <geom type="sphere" pos="0 0 0" size="0.02" material="joint_mat"/>

          <!-- Link 2 / Joint 3 (Z-axis) -->
          <body name="link2" pos="0.0301 0 0.06625">
            <joint name="j3" type="hinge" axis="0 0 1"
                   limited="true" range="-1.484 1.484"/>
            <inertial pos="-0.00210 0.000555 0.0905"
                      mass="1.0739"
                      fullinertia="0.004372 0.004319 0.000661 1e-06 1.1e-05 -3.6e-05"/>
            <geom type="capsule" fromto="0 0 0  0 0 0.154" size="0.028" material="link_mat"/>
            <geom type="sphere" pos="0 0 0" size="0.02" material="joint_mat"/>

            <!-- Link 3 / Joint 4 (Y-axis) -->
            <body name="link3" pos="0 0.0315 0.15375">
              <joint name="j4" type="hinge" axis="0 1 0"
                     limited="true" range="0 2.356"/>
              <inertial pos="-0.00290 -0.03031 0.06340"
                        mass="0.6349"
                        fullinertia="0.000623 0.000511 0.000334 -1e-06 -1.9e-05 3.8e-05"/>
              <geom type="capsule" fromto="0 0 0  0 -0.0315 0.096" size="0.022" material="link_mat"/>
              <geom type="sphere" pos="0 0 0" size="0.018" material="joint_mat"/>

              <!-- Link 4 / Joint 5 (Z-axis) -->
              <body name="link4" pos="0 -0.0315 0.0955">
                <joint name="j5" type="hinge" axis="0 0 1"
                       limited="true" range="-1.484 1.484"/>
                <inertial pos="-0.00305 0.000887 0.04308"
                          mass="0.6157"
                          fullinertia="0.000423 0.000445 0.000324 -8e-06 6e-06 -6e-06"/>
                <geom type="capsule" fromto="0 0 0  0 0 0.12" size="0.02" material="link_mat"/>
                <geom type="sphere" pos="0 0 0" size="0.016" material="joint_mat"/>

                <!-- Link 5 / Joint 6 (X-axis) -->
                <body name="link5" pos="0.0375 0 0.1205">
                  <joint name="j6" type="hinge" axis="1 0 0"
                         limited="true" range="-0.698 0.698"/>
                  <inertial pos="-0.03714 0.000332 -0.0000950"
                            mass="0.4752"
                            fullinertia="0.000143 0.000157 0.000159 1e-06 1e-06 1e-06"/>
                  <geom type="capsule" fromto="0 0 0  -0.0375 0 0" size="0.016" material="link_mat"/>
                  <geom type="sphere" pos="0 0 0" size="0.014" material="joint_mat"/>

                  <!-- Link 6 / Joint 7 (Y-axis) -->
                  <body name="link6" pos="-0.0375 0 0">
                    <joint name="j7" type="hinge" axis="0 1 0"
                           limited="true" range="-1.396 1.396"/>
                    <inertial pos="0.0000688 0.01266 0.06952"
                              mass="0.4660"
                              fullinertia="0.000639 0.000497 0.000342 1e-06 1e-06 8.9e-05"/>
                    <geom type="capsule" fromto="0 0 0  0 0 0.07" size="0.018" material="link_mat"/>
                    <geom type="sphere" pos="0 0 0" size="0.014" material="joint_mat"/>

                    <!-- End-effector site -->
                    <site name="ee" pos="0 0 0.07" size="0.015" rgba="1 0.2 0.2 1"/>

                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor joint="j1" name="a_j1" gear="1"/>
    <motor joint="j2" name="a_j2" gear="1"/>
    <motor joint="j3" name="a_j3" gear="1"/>
    <motor joint="j4" name="a_j4" gear="1"/>
    <motor joint="j5" name="a_j5" gear="1"/>
    <motor joint="j6" name="a_j6" gear="1"/>
    <motor joint="j7" name="a_j7" gear="1"/>
  </actuator>

  <sensor>
    <jointpos joint="j1" name="j1_pos"/>
    <jointpos joint="j2" name="j2_pos"/>
    <jointpos joint="j3" name="j3_pos"/>
    <jointpos joint="j4" name="j4_pos"/>
    <jointpos joint="j5" name="j5_pos"/>
    <jointpos joint="j6" name="j6_pos"/>
    <jointpos joint="j7" name="j7_pos"/>
    <jointvel joint="j1" name="j1_vel"/>
    <jointvel joint="j2" name="j2_vel"/>
    <jointvel joint="j3" name="j3_vel"/>
    <jointvel joint="j4" name="j4_vel"/>
    <jointvel joint="j5" name="j5_vel"/>
    <jointvel joint="j6" name="j6_vel"/>
    <jointvel joint="j7" name="j7_vel"/>
    <framepos objtype="site" objname="ee" name="ee_pos"/>
  </sensor>
</mujoco>
